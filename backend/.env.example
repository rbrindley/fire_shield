# Fire Shield Backend — Environment Variables
# Copy to .env and fill in values

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=data/app.db

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=change-me-admin-token

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=auto
# Optionally pin HuggingFace cache to local dir:
# HF_HOME=/path/to/hf_cache

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=fire_shield_chunks

# ── Retrieval ─────────────────────────────────────────────────────────────────
FTS_TOP_K=30
VECTOR_TOP_K=30
RERANKER_TOP_N=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated if multiple origins needed:
CORS_ORIGINS=["http://localhost:3100"]

# ── NWS alerts ────────────────────────────────────────────────────────────────
NWS_USER_AGENT=fire-shield contact@example.com
